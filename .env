# App Config
APP_URL="http://yoururladress"
APP_LANG="en_EN"
APP_TIMEZONE="Europe/Warsaw"
APP_ENV="development"
APP_NAME="Name your website"
MAIN_EMAIL="Your e-mail adress"

# Database Configuration
# DB_TYPE: 0 = MySQL/MariaDB, 1 = PostgreSQL, 2 = SQLite
DB_TYPE=0
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=yesframework
DB_USER=root
DB_PASS=

# PostgreSQL Schema (if DB_TYPE=1)
DB_PGSQL_SCHEMA=""

# SQLite File Path (if DB_TYPE=2)
DB_SQLITE_PATH=""
